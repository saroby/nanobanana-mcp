{
  "name": "nanobanana-mcp",
  "description": "Google Gemini image generation MCP server (Nano Banana)",
  "version": "1.0.0",
  "author": {
    "name": "saroby"
  },
  "mcpServers": {
    "nanobanana": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/dist/index.js"],
      "env": {
        "GEMINI_API_KEY": "${GEMINI_API_KEY}"
      }
    }
  }
}
